<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/main_screen_background_color"
    android:padding="@dimen/padding_standard">

    <!-- Заголовок -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/main_title"
        android:textColor="@color/yp_white"
        android:textSize="@dimen/text_size_title"
        android:textStyle="bold"
        android:fontFamily="@font/ys_display_medium"
        android:layout_marginBottom="32dp" />

    <!-- Кнопка Поиск -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/search_button"
        style="@style/MainScreenButtonStyle"
        android:text="@string/search"
        app:icon="@drawable/ic_search_24" />

    <!-- Кнопка Медиатека -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/media_button"
        style="@style/MainScreenButtonStyle"
        android:text="@string/media_library"
        app:icon="@drawable/ic_library_24" />

    <!-- Кнопка Настройки -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/settings_button"
        style="@style/MainScreenButtonStyle"
        android:text="@string/settings"
        app:icon="@drawable/ic_settings_24" />

</LinearLayout>
