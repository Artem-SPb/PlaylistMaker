<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yp_blue"
    android:padding="@dimen/padding_standard">

    <!-- Заголовок -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/main_title"
        android:textColor="@color/yp_white"
        android:textSize="@dimen/text_size_title"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- Кнопка Поиск -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/search_button"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/yp_white"
        android:text="@string/search"
        android:textAllCaps="false"
        android:textColor="@color/yp_black"
        android:textSize="@dimen/text_size_22"
        app:cornerRadius="@dimen/button_corner_radius"
        app:icon="@drawable/ic_search_24"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@color/yp_black" />

    <!-- Кнопка Медиатека -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/media_button"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/yp_white"
        android:text="@string/media_library"
        android:textAllCaps="false"
        android:textColor="@color/yp_black"
        android:textSize="@dimen/text_size_22"
        app:cornerRadius="@dimen/button_corner_radius"
        app:icon="@drawable/ic_library_24"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@color/yp_black" />

    <!-- Кнопка Настройки -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/settings_button"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:backgroundTint="@color/yp_white"
        android:text="@string/settings"
        android:textAllCaps="false"
        android:textColor="@color/yp_black"
        android:textSize="@dimen/text_size_22"
        app:cornerRadius="@dimen/button_corner_radius"
        app:icon="@drawable/ic_settings"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@color/yp_black" />

</LinearLayout>
