<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_background_color">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/search"
        app:titleTextAppearance="@style/SettingsItemTextStyle"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:navigationIconTint="@color/primary_text_color" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/search_field_height"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_search_field">

        <EditText
            android:id="@+id/inputEditText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="@string/search"
            android:inputType="text"
            android:maxLines="1"
            android:singleLine="true"
            android:drawableStart="@drawable/ic_search_24"
            android:drawablePadding="8dp"
            android:drawableTint="@color/search_hint_color"
            android:paddingHorizontal="12dp"
            android:textColor="@color/primary_text_color"
            android:textColorHint="@color/search_hint_color"
            android:textSize="16sp"
            android:fontFamily="@font/ys_display_regular"
            android:imeOptions="actionDone"
            android:textCursorDrawable="@drawable/custom_cursor"
            tools:ignore="TouchTargetSizeCheck" />

        <ImageView
            android:id="@+id/clearIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:paddingEnd="12dp"
            android:src="@drawable/ic_clear_24"
            android:visibility="gone"
            app:tint="@color/search_hint_color" />
    </FrameLayout>
</LinearLayout>
